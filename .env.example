# =============================================================================
# Environment variables for under-big-black-sun
# -----------------------------------------------------------------------------
# Copy to `.env` for local dev:  cp .env.example .env  (then fill in values).
#
# IMPORTANT (Vercel): DATABASE_URL, BLOB_READ_WRITE_TOKEN and PAYLOAD_SECRET
# must be set in BOTH the Build AND Runtime environments — NOT runtime only.
# `next build` queries Payload -> Postgres (generateStaticParams, sitemap.ts,
# per-post OG metadata) and runs `payload migrate`, so these are required at
# build time. Missing them in Build will fail the deploy.
# =============================================================================

# Postgres connection string (Neon). Use the POOLED connection string
# (host contains "-pooler") — required for serverless/Vercel functions.
# Neon dashboard -> your project -> Connection Details -> "Pooled connection".
# Format: postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Vercel Blob read/write token (media uploads persist on Blob, never local fs).
# Vercel dashboard -> Storage -> your Blob store -> ".env.local" tab, or it is
# auto-injected when the Blob store is linked to the project.
# Format: vercel_blob_rw_xxxxxxxxxxxxxxxx
BLOB_READ_WRITE_TOKEN=

# Payload secret — signs auth tokens / cookies. Generate a strong random value:
#   openssl rand -hex 32
# Keep this stable across deploys (rotating it invalidates existing sessions).
PAYLOAD_SECRET=

# Public server URL. LOCAL DEV ONLY — leave as localhost.
# In production/preview, getServerURL() derives the URL from Vercel's
# VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL automatically, so you do NOT need
# to set this on Vercel.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
