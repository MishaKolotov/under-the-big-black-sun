# Payload secret — used to sign tokens. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Postgres connection string (Neon). Pooled connection string recommended for serverless.
DATABASE_URL=

# Vercel Blob read/write token for media uploads.
BLOB_READ_WRITE_TOKEN=

# Public server URL used in local dev (Vercel sets VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL in CI).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
