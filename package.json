  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev",
    "build": "payload migrate && next build",
    "start": "next start",
    "lint": "eslint .",
