    "nanoid": "^5.1.11",
    "next": "15.4.11",
    "next-intl": "4.13.0",
    "payload": "3.85.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "20.19.42",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.4.11",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
